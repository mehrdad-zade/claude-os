{
    "project_identity": {
        "name": "YOUR_PROJECT_NAME",
        "root_directory": "./",
        "version": "1.0.0",
        "environment": "development"
    },
    "llm_orchestration": {
        "tiers": {
            "high": {
                "model": "claude-3-5-sonnet-latest",
                "context_caching": true,
                "max_output_tokens": 8192,
                "intent": "Architectural planning and complex logic refactoring"
            },
            "medium": {
                "model": "claude-3-5-haiku-latest",
                "context_caching": true,
                "max_output_tokens": 4096,
                "intent": "Feature implementation and comprehensive unit testing"
            },
            "low": {
                "model": "claude-3-haiku-20240307",
                "context_caching": false,
                "max_output_tokens": 1024,
                "intent": "Metadata tagging, linting, and terminal command verification"
            }
        },
        "default_tier": "medium",
        "global_governance": {
            "stop_sequences": [
                "\n\nHuman:",
                "User:"
            ],
            "temperature": 0.3
        }
    },
    "stack_specification": {
        "backends": [
            {
                "id": "primary-api",
                "language": "Go",
                "framework": "Gin",
                "directory": "./backend"
            },
            {
                "id": "worker-service",
                "language": "Python",
                "framework": "FastAPI",
                "directory": "./workers"
            }
        ],
        "frontend": {
            "framework": "Next.js",
            "styling": "Tailwind CSS",
            "directory": "./web"
        },
        "databases": {
            "sql": "PostgreSQL",
            "no_sql": "Redis",
            "orm": "Prisma"
        }
    },
    "infrastructure": {
        "cloud_provider": "AWS",
        "core_services": [
            "Lambda",
            "S3",
            "RDS",
            "EC2"
        ],
        "third_party_services": [
            "Stripe",
            "SendGrid",
            "Auth0"
        ],
        "deployment_strategy": "Terraform"
    },
    "agentic_capabilities": {
        "agents_path": "./.claude/agents",
        "skills_path": "./.claude/skills",
        "active_agents": [
            "frontend-expert",
            "devops-specialist",
            "db-architect"
        ],
        "rules_enforcement": "strict"
    },
    "behavioral_settings": {
        "indentation": "2-spaces",
        "naming_convention": "camelCase",
        "security_checks_enabled": true
    },
    "agentic_capabilities": {
        "agents_path": "./.claude/agents",
        "skills_path": "./.claude/skills",
        "active_agents": [
            {
                "id": "architect-agent",
                "default_model_tier": "high",
                "description": "System-wide orchestration and structural planning"
            },
            {
                "id": "frontend-expert",
                "default_model_tier": "medium",
                "description": "UI/UX implementation and frontend logic"
            },
            {
                "id": "backend-specialist",
                "default_model_tier": "medium",
                "description": "API development and business logic"
            },
            {
                "id": "db-architect",
                "default_model_tier": "medium",
                "description": "Schema management and query optimization"
            },
            {
                "id": "devops-specialist",
                "default_model_tier": "low",
                "description": "Infrastructure scripts and deployment execution"
            },
            {
                "id": "security-auditor",
                "default_model_tier": "high",
                "description": "Critical vulnerability scanning and compliance"
            }
        ],
        "rules_enforcement": "strict"
    }
}