{
    "_note": "This is a reference file. Copy the server blocks you need into .claude/settings.json under the 'mcpServers' key. All secret values must come from shell environment variables — never hardcode tokens or credentials.",

    "github": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-github"],
        "env": {
            "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
        }
    },

    "filesystem": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "${PROJECT_ROOT}"],
        "_note": "Replace ${PROJECT_ROOT} with the absolute path you want to expose, e.g. /Users/you/myproject"
    },

    "postgres": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-postgres"],
        "env": {
            "DATABASE_URL": "${DATABASE_URL}"
        }
    },

    "slack": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-slack"],
        "env": {
            "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
            "SLACK_TEAM_ID": "${SLACK_TEAM_ID}"
        }
    },

    "aws": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "aws-mcp-server"],
        "env": {
            "AWS_ACCESS_KEY_ID": "${AWS_ACCESS_KEY_ID}",
            "AWS_SECRET_ACCESS_KEY": "${AWS_SECRET_ACCESS_KEY}",
            "AWS_REGION": "${AWS_REGION}"
        }
    },

    "jira": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-jira"],
        "env": {
            "JIRA_URL": "${JIRA_URL}",
            "JIRA_EMAIL": "${JIRA_EMAIL}",
            "JIRA_API_TOKEN": "${JIRA_API_TOKEN}"
        }
    },

    "linear": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-linear"],
        "env": {
            "LINEAR_API_KEY": "${LINEAR_API_KEY}"
        }
    },

    "datadog": {
        "type": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-datadog"],
        "env": {
            "DATADOG_API_KEY": "${DATADOG_API_KEY}",
            "DATADOG_APP_KEY": "${DATADOG_APP_KEY}",
            "DATADOG_SITE": "${DATADOG_SITE}"
        }
    }
}
